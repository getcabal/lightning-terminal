# Copy this file to `paywall-web/env.production.push`, then push it with:
# ./scripts/vercel_paywall_env_push.sh production paywall-web/env.production.push

# DATABASE_URL is already configured on this Vercel project by the Neon integration.
# Uncomment only if you intentionally want to replace it.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/verceldb?sslmode=require
LIGHTNING_NODE_TYPE=lnd
LIGHTNING_NODE_URL=https://your-voltage-node-host:8080
LIGHTNING_API_KEY=replace-with-your-lnd-rest-macaroon-hex
L402_MACAROON_ROOT_KEY=replace-with-a-random-32-byte-hex-root-key
L402_INVOICE_EXPIRY=3600
L402_MIN_AMOUNT_SATS=1
L402_MAX_AMOUNT_SATS=100000
ADMIN_PUBLISH_TOKEN=replace-with-a-long-random-admin-token

# BLOB_READ_WRITE_TOKEN, EDGE_CONFIG, VERCEL_EDGE_CONFIG_ID, and VERCEL_TEAM_ID
# are already configured in Vercel production for this project.
# Uncomment only if you intentionally want to replace them.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_t5ge6aju0pyk30tggusrvw3zioou?token=replace-with-edge-config-token
# VERCEL_EDGE_CONFIG_ID=ecfg_t5ge6aju0pyk30tggusrvw3zioou
# VERCEL_TEAM_ID=team_gOIFFYI3cfxbpQEZ1fMMD2qN

# Optional. Needed only if the publish route should patch Edge Config directly.
# VERCEL_ACCESS_TOKEN=vercel_pat_xxxxxxxxxxxxxxxxxxxx

# Optional. Present in some x402-oriented configs but not used by this app today.
# LIGHTNING_WEBHOOK_SECRET=replace-with-a-random-hex-secret
# L402_SATS_PER_CREDIT=100
